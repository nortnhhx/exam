<Page x:Class="University.Windows.TeachersPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:University.Windows"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Преподаватели">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10"
                 x:Name="ButtonsPanel">
            <Button Content="Добавить" Width="100" Margin="5" Click="AddButton_Click"/>
            <Button Content="Изменить" Width="100" Margin="5" Click="EditButton_Click"/>
            <Button Content="Удалить" Width="100" Margin="5" Click="DeleteButton_Click"/>
            <Button Content="Обновить" Width="100" Margin="5" Click="RefreshButton_Click"/>
        </StackPanel>

        <TextBlock Grid.Row="0" x:Name="GuestInfoText" Text="Режим просмотра (только чтение)" 
                Foreground="Gray" FontStyle="Italic" Margin="0,0,0,10"
                Visibility="Collapsed"/>

        <DataGrid x:Name="TeachersGrid" Grid.Row="1" AutoGenerateColumns="False"
               CanUserAddRows="False" SelectionMode="Single">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Teacher_ID}" Width="50"/>
                <DataGridTextColumn Header="ФИО" Binding="{Binding FullName}" Width="200"/>
                <DataGridTextColumn Header="Категория" Binding="{Binding Category.CategoryName}" Width="100"/>
                <DataGridTextColumn Header="Адрес" Width="250">
                    <DataGridTextColumn.Binding>
                        <MultiBinding StringFormat="{}{0}, д.{1}, кв.{2}">
                            <Binding Path="Street"/>
                            <Binding Path="House"/>
                            <Binding Path="Apartament"/>
                        </MultiBinding>
                    </DataGridTextColumn.Binding>
                </DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>

        <TextBlock Grid.Row="2" x:Name="StatusText" Margin="0,10"/>
    </Grid>
</Page>
