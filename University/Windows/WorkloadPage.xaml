<Page x:Class="University.Windows.WorkloadPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:University.Windows"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Нагрузка">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10"
                 x:Name="ButtonsPanel">
            <Button Content="Добавить" Width="100" Margin="5" Click="AddButton_Click"/>
            <Button Content="Изменить" Width="100" Margin="5" Click="EditButton_Click"/>
            <Button Content="Удалить" Width="100" Margin="5" Click="DeleteButton_Click"/>
            <Button Content="Обновить" Width="100" Margin="5" Click="RefreshButton_Click"/>
        </StackPanel>

        <TextBlock Grid.Row="0" x:Name="GuestInfoText" Text="Режим просмотра (только чтение)" 
                Foreground="Gray" FontStyle="Italic" Margin="0,0,0,10"
                Visibility="Collapsed"/>

        <DataGrid x:Name="WorkloadGrid" Grid.Row="1" AutoGenerateColumns="False"
               CanUserAddRows="False" SelectionMode="Single">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Workload_ID}" Width="50"/>
                <DataGridTextColumn Header="Преподаватель" Width="200">
                    <DataGridTextColumn.Binding>
                        <Binding Path="Teachers.FullName"/>
                    </DataGridTextColumn.Binding>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Предмет" Width="200">
                    <DataGridTextColumn.Binding>
                        <Binding Path="Subject.SubjectName"/>
                    </DataGridTextColumn.Binding>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Цикл" Width="150">
                    <DataGridTextColumn.Binding>
                        <Binding Path="Subject.Cycle.CycleName"/>
                    </DataGridTextColumn.Binding>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Часы" Width="80">
                    <DataGridTextColumn.Binding>
                        <Binding Path="Subject.HourseAmount"/>
                    </DataGridTextColumn.Binding>
                </DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>

        <TextBlock Grid.Row="2" x:Name="StatusText" Margin="0,10"/>
    </Grid>
</Page>
