<Window x:Class="University.Windows.TeacherEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:University.Windows"
        mc:Ignorable="d"
        Title="Преподаватель" Height="550" Width="450"
        WindowStartupLocation="CenterOwner" >
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="1" Text="Данные преподавателя" FontSize="18" FontWeight="Bold"
            Margin="0,0,0,10"/>


        <TextBlock Grid.Row="2" x:Name="IdLabel" Text="ID преподавателя:" Margin="0,10,0,5"/>
        <TextBox Grid.Row="3" x:Name="IdTextBox" Height="30" Margin="0,0,0,10" 
          IsEnabled="False" ToolTip="ID генерируется автоматически"/>
        <TextBlock Grid.Row="4" x:Name="IdReadOnlyText" Visibility="Collapsed" FontWeight="Bold" Margin="5,15,0,5"/>


        <TextBlock Grid.Row="5" x:Name="ManualIdLabel" Text="Введите ID (необязательно):" Margin="0,0,0,5" 
            Foreground="Gray" Visibility="Collapsed"/>
        <TextBox Grid.Row="6" x:Name="ManualIdTextBox" Height="30" Margin="0,0,0,10" 
          Visibility="Collapsed" ToolTip="Оставьте пустым для автоматической генерации"/>

        <TextBlock Grid.Row="7" Text="ФИО преподавателя:" Margin="0,0,0,5"/>
        <TextBox Grid.Row="8" x:Name="FullNameTextBox" Height="30" Margin="0,0,0,10"/>

        <TextBlock Grid.Row="9" Text="Категория:" Margin="0,0,0,5"/>
        <ComboBox Grid.Row="10" x:Name="CategoryComboBox" Height="30" Margin="0,0,0,10"
           DisplayMemberPath="CategoryName"/>

        <TextBlock Grid.Row="11" Text="Адрес проживания:" FontWeight="Bold" Margin="0,10,0,5"/>

        <TextBlock Grid.Row="12" Text="Улица:" Margin="0,0,0,5"/>
        <TextBox Grid.Row="13" x:Name="StreetTextBox" Height="30" Margin="0,0,0,10"/>

        <TextBlock Grid.Row="14" Text="Дом:" Margin="0,0,0,5"/>
        <TextBox Grid.Row="15" x:Name="HouseTextBox" Height="30" Margin="0,0,0,10"/>

        <TextBlock Grid.Row="16" Text="Квартира:" Margin="0,0,0,5"/>
        <TextBox Grid.Row="17" x:Name="ApartmentTextBox" Height="30" Margin="0,0,0,10"/>

        <TextBlock Grid.Row="18" x:Name="ErrorText" Foreground="Red" Margin="0,10"/>

        <StackPanel Grid.Row="19" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Сохранить" Width="100" Height="30" Margin="5" Click="SaveButton_Click"/>
            <Button Content="Отмена" Width="100" Height="30" Margin="5" Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
